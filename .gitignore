# ============================================
# Specific File Exclusions
# ============================================

# Text files in RScripts folder (keep .R files, ignore .txt)
RScripts/*.txt

# Bibliography file in root Analysis folder
# (Zotero-managed, regenerated frequently)
*.bib

# Specific original data files (PII/sensitive)
Data/mv-camp-English-2025-wide-data_originial.dta
Data/my_village_2023_volunteers_originial.dta
Data/my-village-English-baselines-data_originial.dta

# All Excel files in Data folder
Data/*.xlsx

# ============================================
